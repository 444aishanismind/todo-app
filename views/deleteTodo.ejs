<%- include('partials/header') %>

<div class="table-container">
  <h2 class="table-title">Delete Todo</h2>

  <a class="add-button" href="/">Back to list</a>

  <div class="confirm">
    <p>Are you sure you want to delete this task: "<%= todo.title %>"?</p>

    <form action="/deleteTodo/<%= todo._id %>" method="post">
      <button type="submit" class="btn">Yes, delete</button>
      <a class="btn" href="/">No</a>
    </form>
  </div>
</div>

<%- include('partials/footer') %>
